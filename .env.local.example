# ShadowCheck local development overrides
# Copy to .env.local for local-only settings. Do not commit .env.local.

# ----------------------------------------------------------------------------
# Local database
# ----------------------------------------------------------------------------
# Use 127.0.0.1 when the backend runs on your host and PostgreSQL is published
# on localhost by docker/infrastructure/docker-compose.postgres.yml.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=shadowcheck_user
DB_ADMIN_USER=shadowcheck_admin
DB_NAME=shadowcheck_db

# Local Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Server
NODE_ENV=development
PORT=3001

# ----------------------------------------------------------------------------
# Local-only secret overrides
# ----------------------------------------------------------------------------
# Prefer exporting these in your shell instead of writing them to disk. They are
# shown here only to document what local dev requires.
#
# DB_PASSWORD=<local app password>
# DB_ADMIN_PASSWORD=<local admin password>
#
# Geocoding daemon endpoints use the admin DB pool and require DB_ADMIN_PASSWORD
# (or the db_admin_password secret in AWS Secrets Manager if you are intentionally
# pointing at a remote AWS-backed environment).
#
# Optional frontend/dev helpers:
# VITE_API_BASE=http://localhost:3001
# VITE_DEV_MODE=true
