          "rawQuery": true,
          "rawSql": "SELECT\n  CASE\n    WHEN signal >= -50 THEN 'Excellent (>-50)'\n    WHEN signal >= -65 THEN 'Good (-65 to -50)'\n    WHEN signal >= -80 THEN 'Fair (-80 to -65)'\n    ELSE 'Poor (<-80)'\n  END AS signal_quality,\n  COUNT(*)::bigint AS networks\nFROM app.api_network_explorer_mv\nWHERE signal IS NOT NULL AND signal != 0\nGROUP BY 1 ORDER BY networks DESC;",
          "refId": "A"
        }
      ],
      "title": "Signal Strength Quality",
