          "datasource": "ShadowCheck-Postgres",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  LEFT(query, 80) as \"Query\",\n  ROUND(mean_exec_time::numeric, 2) as \"Avg ms\",\n  calls as \"Calls\"\nFROM pg_stat_statements\nWHERE query NOT LIKE '%pg_stat%'\n  AND query NOT LIKE '%BEGIN%'\nORDER BY mean_exec_time DESC\nLIMIT 10",
