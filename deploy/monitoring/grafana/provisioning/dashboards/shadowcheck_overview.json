          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  CASE\n    WHEN threat_score >= 80 THEN '80–100 (Critical)'\n    WHEN threat_score >= 60 THEN '60–80 (High)'\n    WHEN threat_score >= 40 THEN '40–60 (Medium)'\n    WHEN threat_score >= 20 THEN '20–40 (Low)'\n    ELSE '0–20 (None)'\n  END AS score_range,\n  COUNT(*)::bigint AS networks\nFROM app.api_network_explorer_mv\nGROUP BY 1 ORDER BY MIN(threat_score);",
          "refId": "A"
